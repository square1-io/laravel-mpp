# Stripe test keys for the integration tests. Copy to .stripe-test.env (gitignored)
# and fill in, then:  set -a; source .stripe-test.env; set +a; vendor/bin/pest --group=stripe-cross
#
# Two DIFFERENT Stripe test accounts so minting (buyer) and settling (seller) are
# separated, mirroring production. STRIPE_SECRET_KEY is your seller account — the
# same key the package uses to settle (mpp.methods.stripe.secret_key).
# Leave blank to skip the test; fill with sk_test_… keys to run it.
STRIPE_BUYER_SECRET_KEY=   # account A — MINTS the SPT (the buyer/payer)
STRIPE_SECRET_KEY=         # account B — SETTLES it (your seller account)

# Optional override; defaults to 2026-05-27.preview.
# STRIPE_API_VERSION=2026-05-27.preview
